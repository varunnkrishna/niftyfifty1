---
// DESIGN.md §Page states — "Awaiting EOD". Nothing but a muted mono
// eyebrow-style line where EOD will land. No spinner, no skeleton.
interface Props {
	expected?: string;
}
const { expected = '~16:15 IST' } = Astro.props;
---

<hr class="section-divider" />
<p class="awaiting-eod">EOD · EXPECTED {expected}</p>
