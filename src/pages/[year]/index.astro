---
// Year index (PLANNING §3): /YYYY/ — months in that year, reverse-chron, with counts.
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import StructuredData from '../../components/StructuredData.astro';
import { getCollection } from 'astro:content';
import { siteUrl } from '../../config/site';

const MONTH_NAMES = [
	'January', 'February', 'March', 'April', 'May', 'June',
	'July', 'August', 'September', 'October', 'November', 'December',
];

export async function getStaticPaths() {
	const all = await getCollection('docs');
	const years = [...new Set(all.map((e) => (e.data.date as string).slice(0, 4)))];
	return years.map((year) => ({ params: { year }, props: { year } }));
}

const { year } = Astro.props;
const all = await getCollection('docs');
const inYear = all.filter((e) => (e.data.date as string).startsWith(`${year}-`));

const monthCounts = new Map<string, number>();
for (const e of inYear) {
	const month = (e.data.date as string).slice(5, 7);
	monthCounts.set(month, (monthCounts.get(month) ?? 0) + 1);
}
const months = [...monthCounts.entries()].sort((a, b) => b[0].localeCompare(a[0]));
---

<StarlightPage frontmatter={{ title: `${year}`, description: `Archive index for ${year}.`, tableOfContents: false }}>
	<StructuredData breadcrumbs={[{ name: 'Home', url: `${siteUrl}/` }, { name: year, url: `${siteUrl}/${year}/` }]} />
	<p class="eyebrow">Archive</p>

	<div class="card" data-card="year-months">
		<div class="card__head">
			<span class="card__label">{year}</span>
			<span class="card__meta vote-flat">{months.length} months</span>
		</div>
		<div class="card__body">
			<ul class="day-list day-list--flush">
				{
					months.map(([month, count]) => (
						<li>
							<a href={`/${year}/${month}/`}>
								<div class="day-list-title">
									{MONTH_NAMES[Number(month) - 1]} {year}
								</div>
								<div class="day-list-meta">
									{count} day{count === 1 ? '' : 's'}
								</div>
							</a>
						</li>
					))
				}
			</ul>
		</div>
	</div>
</StarlightPage>
