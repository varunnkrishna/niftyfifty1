---
// Month index (PLANNING §3): /YYYY/MM/ — days in that month, reverse-chron.
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import StructuredData from '../../../components/StructuredData.astro';
import { getCollection } from 'astro:content';
import { sortByDateDesc, dayHref, daySummary } from '../../../lib/dayList';
import { siteUrl } from '../../../config/site';

const MONTH_NAMES = [
	'January', 'February', 'March', 'April', 'May', 'June',
	'July', 'August', 'September', 'October', 'November', 'December',
];

export async function getStaticPaths() {
	const all = await getCollection('docs');
	const combos = [...new Set(all.map((e) => (e.data.date as string).slice(0, 7)))]; // YYYY-MM
	return combos.map((ym) => {
		const [year, month] = ym.split('-');
		return { params: { year, month }, props: { year, month } };
	});
}

const { year, month } = Astro.props;
const all = await getCollection('docs');
const inMonth = sortByDateDesc(all.filter((e) => (e.data.date as string).startsWith(`${year}-${month}`)));
const monthName = MONTH_NAMES[Number(month) - 1];
---

<StarlightPage
	frontmatter={{
		title: `${monthName} ${year}`,
		description: `Daily market archive for ${monthName} ${year}.`,
		tableOfContents: false,
	}}
>
	<StructuredData
		breadcrumbs={[
			{ name: 'Home', url: `${siteUrl}/` },
			{ name: year, url: `${siteUrl}/${year}/` },
			{ name: monthName, url: `${siteUrl}/${year}/${month}/` },
		]}
	/>
	<p class="eyebrow">Archive</p>

	<div class="card" data-card="month-days">
		<div class="card__head">
			<span class="card__label">{monthName} {year}</span>
			<span class="card__meta vote-flat">{inMonth.length} days</span>
		</div>
		<div class="card__body">
			<ul class="day-list day-list--flush">
				{
					inMonth.map((entry) => (
						<li>
							<a href={dayHref(entry.data.date as string)}>
								<div class="day-list-title">{entry.data.title}</div>
								<div class="day-list-meta">{daySummary(entry)}</div>
							</a>
						</li>
					))
				}
			</ul>
		</div>
	</div>
</StarlightPage>
